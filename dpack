#!/usr/bin/env bash
# dpack — DeepModeling package manager
# One command to install any DeepModeling tool: dp, dpgen, ...
#
# Usage:
#   dpack install dp                  # auto-detect CUDA, download + install
#   dpack install dp --cuda 12.8      # explicit CUDA version
#   dpack install dp --file ./xxx.sh  # OFFLINE: install from a local .sh (no network)
#   dpack install dp --file ./xxx.sh --sha256 <hex>   # OFFLINE + integrity check
#   dpack install dp --prefix ~/dp    # custom install location
#   dpack list                         # show installed tools
#   dpack help                         # show this message
#
# Design: install dpack to your user dir, then dpack installs tools.
# Works WITHOUT root and WITHOUT network (--file mode) — built for HPC.
# Like pixi / brew but for the DeepModeling ecosystem.

set -euo pipefail

DPACK_HOME="${DPACK_HOME:-$HOME/.dpack}"
MANIFEST_URL="${DPACK_MANIFEST_URL:-https://raw.githubusercontent.com/Isaiah-WU/deepmd-dpack/main/assets/manifest.json}"
INSTALLED_DB="$DPACK_HOME/installed.json"
CACHE_DIR="$DPACK_HOME/cache"

# ── helpers ──────────────────────────────────────────────────────────────────
bold()  { printf "\033[1m%s\033[0m" "$*"; }
green() { printf "\033[32m%s\033[0m" "$*"; }
red()   { printf "\033[31m%s\033[0m" "\n$*" >&2; }
warn()  { printf "\033[33m%s\033[0m" "$*" >&2; }

# Verify a local installer's sha256 in OFFLINE mode.
# Priority: explicit --sha256 (enforced) > a matching sha in the cached manifest
# (enforced-by-match) > warn but proceed (pure-offline, nothing to check against).
verify_offline_sha() {
  local file="$1" want="$2"
  local got; got="$(sha256sum "$file" | cut -d' ' -f1)"
  if [[ -n "$want" ]]; then
    if [[ "$got" != "$want" ]]; then red "SHA256 mismatch: expected $want, got $got"; exit 1; fi
    echo "  $(green "✓") SHA256 verified (--sha256)"
    return
  fi
  local found=""
  if [[ -f "$DPACK_HOME/manifest.json" ]] && command -v python3 >/dev/null 2>&1; then
    found="$(GOT="$got" python3 -c '
import json, os, sys
got = os.environ["GOT"]
try: m = json.load(open(sys.argv[1]))
except Exception: sys.exit(0)
shas = {v.get("sha256") for t in m.get("tools", {}).values()
        for v in t.get("variants", {}).values() if v.get("sha256")}
print("yes" if got in shas else "")
' "$DPACK_HOME/manifest.json" 2>/dev/null)"
  fi
  if [[ "$found" == "yes" ]]; then
    echo "  $(green "✓") SHA256 verified (matches a manifest variant)"
  elif [[ -f "$DPACK_HOME/manifest.json" ]]; then
    warn "  ⚠ this file's sha256 is not in the cached manifest — source not verified (pass --sha256 to enforce)."; echo ""
  else
    warn "  ⚠ no cached manifest to verify against — pass --sha256 <hex> for offline integrity."; echo ""
  fi
}

detect_cuda() {
  command -v nvidia-smi >/dev/null 2>&1 || { echo ""; return; }
  # The driver's max-supported CUDA version is printed in `nvidia-smi` header
  # as "CUDA Version: XX.Y" — NOT the driver_version field (e.g. 580.105).
  nvidia-smi 2>/dev/null | grep -oE 'CUDA Version: [0-9]+\.[0-9]+' | grep -oE '[0-9]+\.[0-9]+' | head -1
}

download_manifest() {
  mkdir -p "$DPACK_HOME"
  curl -fsSL "$MANIFEST_URL" -o "$DPACK_HOME/manifest.json" 2>/dev/null || {
    red "Cannot reach manifest at $MANIFEST_URL"
    exit 1
  }
  cat "$DPACK_HOME/manifest.json"
}

pick_variant() {
  local manifest="$1" tool="$2" cuda="$3"
  if [[ -n "$cuda" ]]; then
    # Exact match wins
    local key="cuda${cuda//./}"
    if echo "$manifest" | grep -q "\"$key\""; then echo "$key"; return; fi
    # Otherwise pick the HIGHEST available CUDA package that is <= driver's CUDA.
    # NVIDIA is backward-compatible: a cuda128 build runs on a 13.0 driver,
    # but a cuda131 build will NOT run on a 13.0 driver.
    local want_num best="" best_num=0
    want_num=$(awk "BEGIN{printf \"%d\", $cuda*10}")
    for v in 13.1 12.9 12.8 12.6; do
      echo "$manifest" | grep -q "\"cuda${v//./}\"" || continue
      local vn; vn=$(awk "BEGIN{printf \"%d\", $v*10}")
      if [[ "$vn" -le "$want_num" && "$vn" -gt "$best_num" ]]; then
        best="cuda${v//./}"; best_num="$vn"
      fi
    done
    if [[ -n "$best" ]]; then echo "$best"; return; fi
  fi
  echo "cpu"
}

cmd_install() {
  local tool="${1:-}" cuda="" version="" localfile="" sha_flag="" prefix="${DPACK_PREFIX:-$HOME/deepmd-kit}"
  shift || true
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --cuda)     cuda="$2"; shift 2 ;;
      --version)  version="$2"; shift 2 ;;
      --file)     localfile="$2"; shift 2 ;;
      --sha256)   sha_flag="$2"; shift 2 ;;  # OFFLINE: enforce this sha256 on --file
      --prefix)   prefix="$2"; shift 2 ;;
      --backend)  shift 2 ;;  # future: per-backend download
      *)          shift ;;
    esac
  done

  if [[ -z "$tool" ]]; then
    red "Usage: dpack install <tool> [--cuda <ver>] [--file <path>] [--prefix <dir>]"
    exit 1
  fi

  # ── OFFLINE mode: install from a local .sh (or its split parts) ──────────────
  if [[ -n "$localfile" ]]; then
    # Auto-reassemble split parts: if given foo.sh and foo.sh.0 exists, cat them.
    if [[ ! -f "$localfile" && -f "${localfile}.0" ]]; then
      echo "  Reassembling split parts ${localfile}.* ..."
      cat "${localfile}".[0-9]* > "$localfile"
    fi
    [[ -f "$localfile" ]] || { red "File not found: $localfile"; exit 1; }
    echo "  Offline install from $(bold "$localfile")"
    verify_offline_sha "$localfile" "$sha_flag"
    echo "  Installing $tool to $prefix ..."
    bash "$localfile" -b -p "$prefix"
    record_install "$tool" "local" "$cuda" "$prefix"
    echo ""
    echo "  $(green "✓") $tool installed to $(bold "$prefix")"
    echo "  Activate: source $prefix/bin/activate $prefix"
    return
  fi

  # Auto-detect CUDA
  if [[ -z "$cuda" ]]; then
    cuda="$(detect_cuda)"
    if [[ -n "$cuda" ]]; then
      echo "  Auto-detected CUDA $(green "$cuda")"
    else
      echo "  No GPU detected, defaulting to CPU"
    fi
  fi

  echo "  Downloading manifest..."
  local manifest
  manifest="$(download_manifest)"

  # Pick best variant
  local variant
  variant="$(pick_variant "$manifest" "$tool" "$cuda")"
  # A variant has EITHER a single "url" OR a list of "parts" (split installers,
  # because GitHub caps a release asset at 2 GiB). Extract both + sha256.
  local urls sha
  urls="$(echo "$manifest" | python3 -c "
import json,sys
v=json.load(sys.stdin)['tools']['$tool']['variants']['$variant']
parts=v.get('parts')
print('\n'.join(parts) if parts else v.get('url',''))
" 2>/dev/null || echo "")"
  sha="$(echo "$manifest" | python3 -c "
import json,sys
print(json.load(sys.stdin)['tools']['$tool']['variants']['$variant'].get('sha256',''))
" 2>/dev/null || echo "")"

  if [[ -z "$urls" ]]; then
    red "No installer found for $tool ($variant). Available:"
    echo "$manifest" | python3 -c "
import json,sys
for k,v in json.load(sys.stdin)['tools']['$tool']['variants'].items():
    print(f'    {k} (cuda={v.get(\"cuda\",\"cpu\")})')
" 2>/dev/null || echo "    (could not parse manifest)"
    exit 1
  fi

  echo "  Selected: $(bold "$tool") variant $(green "$variant")"
  mkdir -p "$CACHE_DIR"
  local installer="$CACHE_DIR/${tool}-${variant}.sh"
  local n; n="$(echo "$urls" | wc -l)"
  if [[ "$n" -gt 1 ]]; then
    echo "  Downloading $n split parts and reassembling ..."
    : > "$installer"
    local i=0
    while IFS= read -r part_url; do
      i=$((i+1))
      echo "    part $i/$n ..."
      local pf="$CACHE_DIR/${tool}-${variant}.part$i"
      # Skip parts already fully downloaded. Without this, `-C -` resume on a
      # COMPLETE file makes the server return HTTP 416 (range not satisfiable),
      # which would abort a re-run even though the part is already done.
      local remote_size local_size=0
      remote_size="$(curl -fsSLI "$part_url" 2>/dev/null | awk -F': ' 'tolower($1)=="content-length"{gsub(/[^0-9]/,"",$2); print $2}' | tail -1)"
      [[ -f "$pf" ]] && local_size="$(stat -c%s "$pf" 2>/dev/null || echo 0)"
      if [[ -n "$remote_size" && "$local_size" == "$remote_size" ]]; then
        echo "      (already complete, skipping)"
        continue
      fi
      # --retry + -C - (resume) survive flaky GitHub large-file connections.
      curl -fSL --retry 5 --retry-delay 3 -C - --progress-bar "$part_url" -o "$pf" || {
        red "Download failed on part $i after retries. Re-run; finished parts are cached."
        exit 1
      }
    done <<< "$urls"
    cat "$CACHE_DIR/${tool}-${variant}".part[0-9]* > "$installer"
    rm -f "$CACHE_DIR/${tool}-${variant}".part[0-9]*
  else
    echo "  Downloading from $urls ..."
    curl -fSL --retry 5 --retry-delay 3 -C - --progress-bar "$urls" -o "$installer" || {
      red "Download failed. The installer may not be released yet."
      exit 1
    }
  fi

  # Verify sha256 if available
  if [[ -n "$sha" ]]; then
    local got
    got="$(sha256sum "$installer" | cut -d' ' -f1)"
    if [[ "$got" != "$sha" ]]; then
      red "SHA256 mismatch: expected $sha, got $got"
      exit 1
    fi
    echo "  SHA256 verified"
  fi

  # Install
  echo "  Installing $tool to $prefix ..."
  bash "$installer" -b -p "$prefix"
  record_install "$tool" "$variant" "$cuda" "$prefix"

  echo ""
  echo "  $(green "✓") $tool installed to $(bold "$prefix")"
  echo "  Activate: source $prefix/bin/activate $prefix"
  echo "  Verify:   dp --version"
}

record_install() {
  local tool="$1" variant="$2" cuda="$3" prefix="$4"
  mkdir -p "$DPACK_HOME"
  echo "{\"tool\":\"$tool\",\"variant\":\"$variant\",\"cuda\":\"$cuda\",\"prefix\":\"$prefix\"}" > "$DPACK_HOME/installed-$tool.json"
  echo "$tool $variant $prefix" >> "$INSTALLED_DB" 2>/dev/null || true
}

cmd_list() {
  if [[ -f "$INSTALLED_DB" ]]; then
    echo "Installed tools:"
    cat "$INSTALLED_DB"
  else
    echo "No tools installed yet. Try: dpack install dp"
  fi
}

cmd_help() {
  sed -n '2,12p' "${BASH_SOURCE[0]}" | sed 's/^# //'
  echo ""
  echo "Examples:"
  echo "  dpack install dp                     # auto-detect GPU, install latest"
  echo "  dpack install dp --cuda 12.8          # explicit CUDA"
  echo "  dpack list                            # show installed tools"
}

# ── main ──────────────────────────────────────────────────────────────────────
mkdir -p "$DPACK_HOME" "$CACHE_DIR"
case "${1:-help}" in
  install) shift; cmd_install "$@" ;;
  list)    shift; cmd_list "$@" ;;
  help|--help|-h) cmd_help ;;
  *)       red "Unknown command: ${1:-}"; cmd_help; exit 1 ;;
esac
